<?xml version="1.0" encoding="UTF-8"?>
<!--
  storage/web.config — IIS
  Bloqueia QUALQUER acesso HTTP directo à pasta storage/
  Os ficheiros são servidos APENAS pelo DownloadController.php
-->
<configuration>
  <system.webServer>

    <!-- Nega todo o acesso directo via rewrite -->
    <rewrite>
      <rules>
        <rule name="DenyStorageDirect" stopProcessing="true">
          <match url=".*" />
          <action type="CustomResponse"
                  statusCode="403"
                  statusReason="Forbidden"
                  statusDescription="Direct access to this directory is not allowed." />
        </rule>
      </rules>
    </rewrite>

    <directoryBrowse enabled="false" />

  </system.webServer>
</configuration>
