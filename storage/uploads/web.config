<?xml version="1.0" encoding="UTF-8"?>
<!--
  storage/uploads/web.config — IIS
  Bloqueia acesso HTTP directo aos ficheiros de upload.
  Acesso permitido APENAS via DownloadController.php (PHP)
-->
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <rule name="DenyUploadsDirect" stopProcessing="true">
          <match url=".*" />
          <action type="CustomResponse"
                  statusCode="403"
                  statusReason="Forbidden"
                  statusDescription="Direct file access is not permitted." />
        </rule>
      </rules>
    </rewrite>

    <directoryBrowse enabled="false" />

  </system.webServer>
</configuration>
